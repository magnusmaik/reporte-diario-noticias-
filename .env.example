# Plantilla de credenciales para correr el script localmente.
# En GitHub Actions estas variables vienen de Secrets; este archivo no se usa allí.
# Copia a .env y rellena los valores reales. NUNCA commitees .env (.gitignore ya lo excluye).

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Opcionales (con defaults sensatos en el script)
OPENROUTER_MODEL=perplexity/sonar
REPORT_RECIPIENT=miguel.carsub@gmail.com
REPORT_FROM=Reporte Diario <onboarding@resend.dev>
